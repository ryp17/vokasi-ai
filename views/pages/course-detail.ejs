<%- include('../partials/head', { pageTitle: pageTitle }) %>

    <!-- Hero Section -->
    <section style="padding-top: calc(var(--spacing-lg) + var(--header-height)); padding-bottom: var(--spacing-lg); background-color: var(--clr-primary); color: var(--clr-white);">
        <div class="container" style="max-width: 1000px;">
            
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" style="margin-bottom: 2rem;">
                <ol style="list-style: none; display: flex; gap: 0.5rem; font-size: 0.9rem; flex-wrap: wrap; margin: 0; padding: 0;">
                    <li><a href="/" style="color: rgba(255,255,255,0.7); font-weight: 600;">Home</a></li>
                    <li><span style="color: rgba(255,255,255,0.3);">/</span></li>
                    <li><a href="/kursus-online" style="color: rgba(255,255,255,0.7); font-weight: 600;">Kategori Kursus</a></li>
                    <li><span style="color: rgba(255,255,255,0.3);">/</span></li>
                    <li aria-current="page" style="color: var(--clr-white);"><%= course.title %></li>
                </ol>
            </nav>

            <div class="grid grid-2" style="gap: 4rem; align-items: center;">
                <div>
                    <% if (course.isComingSoon) { %>
                        <span style="display: inline-block; background: rgba(59, 130, 246, 0.2); color: #93C5FD; font-size: 0.8rem; font-weight: 800; padding: 6px 14px; border-radius: 20px; letter-spacing: 0.5px; margin-bottom: 1.5rem; border: 1px solid rgba(59, 130, 246, 0.5);">SEGERA HADIR</span>
                    <% } else { %>
                        <span style="display: inline-block; background: rgba(59, 130, 246, 0.2); color: #93C5FD; font-size: 0.8rem; font-weight: 800; padding: 6px 14px; border-radius: 20px; letter-spacing: 0.5px; margin-bottom: 1.5rem; border: 1px solid rgba(59, 130, 246, 0.5);"><%= course.category.toUpperCase() %></span>
                    <% } %>
                    
                    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 1.5rem; line-height: 1.2; color: var(--clr-white);"><%= course.title %></h1>
                    <p style="font-size: 1.15rem; color: rgba(255,255,255,0.8); margin-bottom: 2rem; line-height: 1.6;">
                        <%= course.description %>
                    </p>
                    
                    <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 2rem; align-items: center;">
                        <div style="display: flex; gap: 0.5rem; align-items: center; color: #FCD34D;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <span style="font-weight: 700; color: var(--clr-white);">4.9</span>
                            <span style="color: rgba(255,255,255,0.6); font-size: 0.9rem;">(120+ Ulasan)</span>
                        </div>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            <span style="color: rgba(255,255,255,0.8); font-size: 0.95rem;">1,500+ Pelajar</span>
                        </div>
                    </div>
                </div>
                
                <div style="display: flex; justify-content: center;">
                    <!-- Floating abstract illustration card -->
                    <div style="width: 100%; max-width: 380px; aspect-ratio: 4/3; background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%); border-radius: var(--radius-lg); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
                        <% if (course.isComingSoon) { %>
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <% } else { %>
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content Grid -->
    <section style="padding: var(--spacing-lg) 0; background-color: var(--clr-bg);">
        <div class="container" style="max-width: 1000px;">
            <div style="display: grid; grid-template-columns: 1fr 380px; gap: 4rem; align-items: start;">
                
                <!-- Left Column (Content) -->
                <div style="display: flex; flex-direction: column; gap: 3rem;">
                    
                    <!-- Syllabus -->
                    <div class="white-card" style="padding: 2.5rem; border-radius: var(--radius-lg); border: 1px solid var(--clr-border);">
                        <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Silabus Kursus</h2>
                        <div style="display: flex; flex-direction: column; gap: 1rem;">
                            <% course.syllabus.forEach((mod, index) => { %>
                                <div style="border: 1px solid var(--clr-border); border-radius: var(--radius-md); padding: 1.5rem; background: var(--clr-white);">
                                    <h3 style="font-size: 1.15rem; color: var(--clr-text-main); margin-bottom: 0.5rem;"><%= mod.title %></h3>
                                    <p style="color: var(--clr-text-muted); font-size: 0.95rem; margin: 0;"><%= mod.desc %></p>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Testimonials (Only if NOT coming soon) -->
                    <% if (!course.isComingSoon) { %>
                        <div>
                            <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Kata Mereka yang Lulus</h2>
                            <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
                                <!-- Review 1 -->
                                <div class="white-card" style="padding: 2rem; border-radius: var(--radius-lg); border: 1px solid var(--clr-border);">
                                    <div style="color: #FCD34D; margin-bottom: 1rem; display: flex; gap: 0.25rem;">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                    </div>
                                    <p style="font-size: 1.05rem; color: var(--clr-text-main); line-height: 1.6; margin-bottom: 1.5rem; font-style: italic;">
                                        "Materi yang disampaikan sangat terstruktur dan mudah dipahami, bahkan untuk saya yang pemula. Sekarang saya sudah berhasil mengimplementasikan ilmu ini di pekerjaan saya."
                                    </p>
                                    <div style="display: flex; align-items: center; gap: 1rem;">
                                        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--clr-secondary); color: var(--clr-white); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem;">AD</div>
                                        <div>
                                            <div style="font-weight: 700; font-size: 0.95rem; color: var(--clr-text-main);">Andi Darmawan</div>
                                            <div style="font-size: 0.85rem; color: var(--clr-text-muted);">Alumni Batch 4</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>

                    <!-- FAQ -->
                    <div>
                        <h2 style="font-size: 1.75rem; margin-bottom: 2rem;">Pertanyaan Umum (FAQ)</h2>
                        <div style="display: flex; flex-direction: column; gap: 1rem;">
                            <!-- FAQ Item 1 -->
                            <div class="white-card" style="padding: 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--clr-border);">
                                <h3 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.75rem;">Apakah kursus ini cocok untuk pemula?</h3>
                                <p style="color: var(--clr-text-muted); font-size: 0.95rem; margin: 0;">Ya, materi dirancang dari tingkat dasar hingga menengah, sangat cocok untuk pemula tanpa latar belakang khusus.</p>
                            </div>
                            <!-- FAQ Item 2 -->
                            <div class="white-card" style="padding: 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--clr-border);">
                                <h3 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.75rem;">Apakah saya akan mendapatkan sertifikat?</h3>
                                <p style="color: var(--clr-text-muted); font-size: 0.95rem; margin: 0;">Tentu. Setelah menyelesaikan seluruh modul dan tugas akhir, Anda akan menerima sertifikat kelulusan digital.</p>
                            </div>
                            <!-- FAQ Item 3 -->
                            <div class="white-card" style="padding: 1.5rem; border-radius: var(--radius-md); border: 1px solid var(--clr-border);">
                                <h3 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.75rem;">Berapa lama akses ke materi?</h3>
                                <p style="color: var(--clr-text-muted); font-size: 0.95rem; margin: 0;">Akses materi adalah seumur hidup (lifetime access) setelah Anda tergabung dalam kelas.</p>
                            </div>
                        </div>
                    </div>
                    
                </div>
                
                <!-- Right Column (Sticky Pricing / CTA Card) -->
                <div style="position: sticky; top: calc(var(--header-height) + 2rem);">
                    <div class="white-card" style="padding: 2.5rem; border-radius: var(--radius-lg); border: 1px solid var(--clr-border); box-shadow: 0 10px 40px rgba(0,0,0,0.06);">
                        <% if (course.isComingSoon) { %>
                            <div style="text-align: center; margin-bottom: 2rem;">
                                <div style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; border-radius: 50%; background: #EFF6FF; color: var(--clr-secondary); margin-bottom: 1rem;">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                </div>
                                <h3 style="font-size: 1.5rem; color: var(--clr-text-main); margin-bottom: 0.5rem;">Dapatkan Akses Awal</h3>
                                <p style="font-size: 0.95rem; color: var(--clr-text-muted); line-height: 1.5;">Jadilah yang pertama tahu saat kelas ini diluncurkan dan dapatkan diskon eksklusif pre-launch.</p>
                            </div>
                            
                            <form id="courseApplyForm" style="display: flex; flex-direction: column; gap: 1rem;">
                                <div>
                                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="name">Nama Lengkap</label>
                                    <input type="text" id="name" name="name" required style="width: 100%; padding: 12px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 0.95rem;" placeholder="Budi Santoso">
                                </div>
                                <div>
                                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="email">Email Aktif</label>
                                    <input type="email" id="email" name="email" required style="width: 100%; padding: 12px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 0.95rem;" placeholder="budi@email.com">
                                </div>
                                <div>
                                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="whatsapp">No. WhatsApp</label>
                                    <input type="tel" id="whatsapp" name="whatsapp" required style="width: 100%; padding: 12px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 0.95rem;" placeholder="0812xxxxxx">
                                </div>
                                <input type="hidden" name="subject" value="Waitlist: <%= course.title %>">
                                <button type="submit" id="submitBtn" class="btn btn-primary btn-full" style="padding: 16px; font-size: 1rem; border-radius: var(--radius-sm); margin-top: 0.5rem;">Gabung Waitlist</button>
                                <p style="text-align: center; font-size: 0.8rem; color: var(--clr-text-muted); margin-top: 0.5rem;">100% Gratis. Tanpa spam.</p>
                            </form>
                        <% } else { %>
                            <div style="margin-bottom: 2rem;">
                                <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
                                    <span style="font-size: 2rem; font-weight: 800; color: var(--clr-text-main);"><%= course.price %></span>
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <span style="font-size: 1.1rem; color: var(--clr-text-muted); text-decoration: line-through;"><%= course.originalPrice %></span>
                                    <span style="background: #FEE2E2; color: #DC2626; font-size: 0.75rem; font-weight: 700; padding: 4px 8px; border-radius: 4px;">DISKON 50%</span>
                                </div>
                            </div>
                            
                            <ul style="list-style: none; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1rem;">
                                <li style="display: flex; align-items: flex-start; gap: 0.75rem;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" style="flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    <span style="font-size: 0.95rem; color: var(--clr-text-main);">Akses materi seumur hidup</span>
                                </li>
                                <li style="display: flex; align-items: flex-start; gap: 0.75rem;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" style="flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    <span style="font-size: 0.95rem; color: var(--clr-text-main);">Sertifikat kelulusan digital</span>
                                </li>
                                <li style="display: flex; align-items: flex-start; gap: 0.75rem;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" style="flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    <span style="font-size: 0.95rem; color: var(--clr-text-main);">Grup diskusi eksklusif</span>
                                </li>
                            </ul>

                            <h4 style="font-size: 1rem; color: var(--clr-text-main); margin-bottom: 1rem; border-top: 1px solid var(--clr-border); padding-top: 1.5rem;">Daftar Sekarang</h4>
                            <form id="courseApplyForm" style="display: flex; flex-direction: column; gap: 1rem;">
                                <div>
                                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="name">Nama Lengkap</label>
                                    <input type="text" id="name" name="name" required style="width: 100%; padding: 12px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 0.95rem;" placeholder="Budi Santoso">
                                </div>
                                <div>
                                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="email">Email Aktif</label>
                                    <input type="email" id="email" name="email" required style="width: 100%; padding: 12px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 0.95rem;" placeholder="budi@email.com">
                                </div>
                                <div>
                                    <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="whatsapp">No. WhatsApp</label>
                                    <input type="tel" id="whatsapp" name="whatsapp" required style="width: 100%; padding: 12px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 0.95rem;" placeholder="0812xxxxxx">
                                </div>
                                <input type="hidden" name="subject" value="Daftar Kelas: <%= course.title %>">
                                <button type="submit" id="submitBtn" class="btn btn-primary btn-full" style="padding: 16px; font-size: 1rem; border-radius: var(--radius-sm); margin-top: 0.5rem;">Daftar Kelas</button>
                            </form>
                        <% } %>
                    </div>
                </div>
                
            </div>
        </div>
    </section>

    <!-- Mobile Styles for Grid -->
    <style>
        @media (max-width: 900px) {
            .grid-2 { grid-template-columns: 1fr !important; gap: 2rem !important; }
            section .container > div[style*="display: grid"] { grid-template-columns: 1fr !important; gap: 3rem !important; }
            div[style*="position: sticky"] { position: relative !important; top: 0 !important; }
        }
    </style>

    <script>
        const courseApplyForm = document.getElementById('courseApplyForm');
        const submitBtn = document.getElementById('submitBtn');
        if (courseApplyForm) {
            courseApplyForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const originalText = submitBtn.innerText;
                submitBtn.innerText = 'Memproses...';
                submitBtn.style.opacity = '0.7';
                submitBtn.disabled = true;

                const formData = new FormData(courseApplyForm);
                const data = Object.fromEntries(formData.entries());

                try {
                    const res = await fetch('/api/apply', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    if (res.ok) {
                        submitBtn.innerHTML = 'Berhasil! ✓';
                        submitBtn.style.background = '#10B981';
                        submitBtn.style.borderColor = '#10B981';
                        courseApplyForm.reset();
                    } else {
                        throw new Error('Network response was not ok');
                    }
                } catch (error) {
                    submitBtn.innerText = 'Gagal, Coba Lagi';
                } finally {
                    setTimeout(() => {
                        submitBtn.innerText = originalText;
                        submitBtn.style.background = '';
                        submitBtn.style.borderColor = '';
                        submitBtn.style.opacity = '1';
                        submitBtn.disabled = false;
                    }, 3000);
                }
            });
        }
    </script>

<%- include('../partials/footer') %>
