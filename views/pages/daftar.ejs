<%- include('../partials/head', { pageTitle: pageTitle }) %>

<section style="padding-top: calc(var(--spacing-xl) + var(--header-height)); padding-bottom: var(--spacing-xl); background-color: var(--clr-bg);">
    <div class="container" style="max-width: 1200px;">
        
        <div style="text-align: center; margin-bottom: 4rem;">
            <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); color: var(--clr-text-main); margin-bottom: 1rem; line-height: 1.2;">Mulai Perjalanan Karirmu</h1>
            <p style="font-size: 1.15rem; color: var(--clr-text-muted); max-width: 600px; margin: 0 auto; line-height: 1.6;">
                Pilih program yang sesuai dengan tujuanmu dan ambil langkah pertama untuk menguasai skill yang paling dicari industri saat ini.
            </p>
        </div>

        <div class="grid daftar-grid" style="align-items: start; gap: 4rem;">
            
            <!-- Left: Form Section -->
            <div class="white-card" style="padding: 3rem; border-radius: var(--radius-lg); box-shadow: 0 20px 40px rgba(0,0,0,0.05); border: 1px solid var(--clr-border);">
                <h2 style="font-size: 1.5rem; margin-bottom: 2rem; color: var(--clr-text-main);">Formulir Pendaftaran</h2>
                
                <form id="mainRegistrationForm" style="display: flex; flex-direction: column; gap: 1.5rem;">
                    <!-- Data Diri -->
                    <div>
                        <label style="display: block; font-size: 0.9rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="fullName">Nama Lengkap *</label>
                        <input type="text" id="fullName" name="fullName" required style="width: 100%; padding: 14px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 1rem;" placeholder="Masukkan nama lengkap">
                    </div>
                    
                    <div class="grid grid-2" style="gap: 1.5rem;">
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="emailAddress">Email Aktif *</label>
                            <input type="email" id="emailAddress" name="emailAddress" required style="width: 100%; padding: 14px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 1rem;" placeholder="nama@email.com">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="whatsapp">No. WhatsApp *</label>
                            <input type="tel" id="whatsapp" name="whatsapp" required style="width: 100%; padding: 14px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 1rem;" placeholder="0812xxxxxx">
                        </div>
                    </div>

                    <!-- Pilihan Program -->
                    <div style="margin-top: 1rem; border-top: 1px solid var(--clr-border); padding-top: 1.5rem;">
                        <label style="display: block; font-size: 0.9rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 1rem;">Pilih Tipe Program *</label>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                            <!-- Radio Option 1 -->
                            <label style="cursor: pointer; position: relative;">
                                <input type="radio" name="programType" value="kursus" class="peer" style="position: absolute; opacity: 0; width: 0; height: 0;" required onchange="toggleProgramSelect()">
                                <div class="program-radio-card" style="padding: 1.25rem; border: 2px solid var(--clr-border); border-radius: var(--radius-sm); transition: all 0.2s; height: 100%;">
                                    <div style="font-weight: 700; color: var(--clr-text-main); margin-bottom: 0.25rem;">Kursus Online</div>
                                    <div style="font-size: 0.85rem; color: var(--clr-text-muted);">Belajar mandiri 1 topik spesifik</div>
                                </div>
                            </label>
                            <!-- Radio Option 2 -->
                            <label style="cursor: pointer; position: relative;">
                                <input type="radio" name="programType" value="pathway" class="peer" style="position: absolute; opacity: 0; width: 0; height: 0;" required onchange="toggleProgramSelect()">
                                <div class="program-radio-card" style="padding: 1.25rem; border: 2px solid var(--clr-border); border-radius: var(--radius-sm); transition: all 0.2s; height: 100%;">
                                    <div style="font-weight: 700; color: var(--clr-text-main); margin-bottom: 0.25rem;">Jalur Karir (Pathway)</div>
                                    <div style="font-size: 0.85rem; color: var(--clr-text-muted);">Bootcamp intensif 4 bulan</div>
                                </div>
                            </label>
                        </div>

                        <!-- Kursus Online Select -->
                        <div id="kursusSelectContainer" style="display: none;">
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="kursusOption">Pilih Kursus *</label>
                            <select id="kursusOption" name="selectedProgram" style="width: 100%; padding: 14px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 1rem; background-color: var(--clr-white); cursor: pointer;">
                                <option value="" disabled selected>-- Pilih Kursus Online --</option>
                                <option value="Online Marketing Fundamental">Online Marketing Fundamental</option>
                                <option value="Social Media Fundamental">Social Media Fundamental</option>
                                <option value="Cyber Security">Cyber Security (Waitlist)</option>
                                <option value="Performance Marketing">Performance Marketing (Waitlist)</option>
                                <option value="Blockchain Fundamental">Blockchain Fundamental (Waitlist)</option>
                                <option value="Product Management">Product Management (Waitlist)</option>
                            </select>
                        </div>

                        <!-- Jalur Karir Select -->
                        <div id="pathwaySelectContainer" style="display: none;">
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; color: var(--clr-text-main); margin-bottom: 0.5rem;" for="pathwayOption">Pilih Jalur Karir *</label>
                            <select id="pathwayOption" name="selectedProgram" style="width: 100%; padding: 14px 16px; border-radius: var(--radius-sm); border: 1px solid var(--clr-border); font-family: var(--font-main); font-size: 1rem; background-color: var(--clr-white); cursor: pointer;">
                                <option value="" disabled selected>-- Pilih Jalur Karir --</option>
                                <option value="AI Generalist">AI Generalist</option>
                                <option value="AI Marketer">AI Marketer</option>
                            </select>
                        </div>
                    </div>
                    
                    <div style="margin-top: 1rem;">
                        <button type="submit" id="submitRegBtn" class="btn btn-primary btn-full" style="padding: 18px; font-size: 1.1rem; border-radius: var(--radius-sm);">Kirim Pendaftaran</button>
                        <p style="text-align: center; font-size: 0.85rem; color: var(--clr-text-muted); margin-top: 1rem;">Tim kami akan menghubungi Anda via WhatsApp dalam 1x24 jam kerja.</p>
                    </div>
                </form>
            </div>

            <!-- Right: Info Section -->
            <div style="display: flex; flex-direction: column; gap: 2rem;">
                
                <div style="background: linear-gradient(135deg, var(--clr-primary) 0%, #1E3A8A 100%); border-radius: var(--radius-lg); padding: 2.5rem; color: white;">
                    <h3 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Informasi Program</h3>
                    
                    <div style="margin-bottom: 2rem;">
                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                            <div style="width: 32px; height: 32px; background: rgba(255,255,255,0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                            </div>
                            <h4 style="font-size: 1.1rem; margin: 0;">Kursus Online (Mandiri)</h4>
                        </div>
                        <p style="font-size: 0.95rem; color: rgba(255,255,255,0.8); line-height: 1.5; margin-bottom: 0.75rem;">Cocok untuk upgrade satu skill spesifik secara cepat. Belajar mandiri melalui video dan materi interaktif.</p>
                        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.9);">
                            <li>✓ Akses materi seumur hidup</li>
                            <li>✓ Sertifikat kelulusan digital</li>
                            <li>✓ Rp 499.000 / kelas</li>
                        </ul>
                    </div>
                    
                    <div style="width: 100%; height: 1px; background: rgba(255,255,255,0.2); margin-bottom: 2rem;"></div>
                    
                    <div>
                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                            <div style="width: 32px; height: 32px; background: rgba(255,255,255,0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                            </div>
                            <h4 style="font-size: 1.1rem; margin: 0;">Jalur Karir (Bootcamp)</h4>
                        </div>
                        <p style="font-size: 0.95rem; color: rgba(255,255,255,0.8); line-height: 1.5; margin-bottom: 0.75rem;">Program intensif 4 bulan. Dipandu langsung oleh mentor profesional hingga siap disalurkan kerja.</p>
                        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.9);">
                            <li>✓ Mentoring intensif 1-on-1</li>
                            <li>✓ Dukungan karir (Review CV, Interview)</li>
                            <li>✓ Mulai dari Rp 3.500.000 / program</li>
                        </ul>
                    </div>
                </div>
                
                <div class="white-card" style="padding: 2rem; border-radius: var(--radius-lg); border: 1px solid var(--clr-border); display: flex; gap: 1rem; align-items: flex-start;">
                    <div style="color: var(--clr-secondary); flex-shrink: 0;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    </div>
                    <div>
                        <h4 style="font-size: 1.05rem; color: var(--clr-text-main); margin-bottom: 0.5rem;">Butuh Bantuan Memilih?</h4>
                        <p style="font-size: 0.9rem; color: var(--clr-text-muted); line-height: 1.5; margin-bottom: 1rem;">Tim konselor kami siap membantu Anda menentukan jalur pembelajaran yang paling tepat untuk karir Anda.</p>
                        <a href="https://wa.me/6281200000000" target="_blank" style="color: #25D366; font-weight: 700; font-size: 0.9rem; text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                            Hubungi Konselor via WA
                        </a>
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>

<style>
    .daftar-grid { grid-template-columns: 1fr 400px; }
    
    input.peer:checked + .program-radio-card {
        border-color: var(--clr-secondary) !important;
        background-color: #EFF6FF !important;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
    }
    
    @media (max-width: 900px) {
        .daftar-grid { grid-template-columns: 1fr !important; }
    }
</style>

<script>
    function toggleProgramSelect() {
        const programType = document.querySelector('input[name="programType"]:checked').value;
        const kursusSelect = document.getElementById('kursusSelectContainer');
        const pathwaySelect = document.getElementById('pathwaySelectContainer');
        const kursusInput = document.getElementById('kursusOption');
        const pathwayInput = document.getElementById('pathwayOption');

        if (programType === 'kursus') {
            kursusSelect.style.display = 'block';
            kursusInput.required = true;
            kursusInput.disabled = false;
            
            pathwaySelect.style.display = 'none';
            pathwayInput.required = false;
            pathwayInput.disabled = true;
        } else if (programType === 'pathway') {
            kursusSelect.style.display = 'none';
            kursusInput.required = false;
            kursusInput.disabled = true;

            pathwaySelect.style.display = 'block';
            pathwayInput.required = true;
            pathwayInput.disabled = false;
        }
    }

    const regForm = document.getElementById('mainRegistrationForm');
    const submitRegBtn = document.getElementById('submitRegBtn');
    if (regForm) {
        regForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const originalText = submitRegBtn.innerText;
            submitRegBtn.innerText = 'Memproses...';
            submitRegBtn.style.opacity = '0.7';
            submitRegBtn.disabled = true;

            const formData = new FormData(regForm);
            const data = Object.fromEntries(formData.entries());
            
            // Format the subject based on selection
            data.subject = `Pendaftaran ${data.programType === 'kursus' ? 'Kursus' : 'Jalur Karir'}: ${data.selectedProgram}`;
            // Use standard email mapping for consistency with `/api/apply` if needed
            data.email = data.emailAddress; 
            data.name = data.fullName;

            try {
                const res = await fetch('/api/apply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (res.ok) {
                    submitRegBtn.innerHTML = 'Berhasil Terkirim ✓';
                    submitRegBtn.style.background = '#10B981';
                    submitRegBtn.style.borderColor = '#10B981';
                    regForm.reset();
                    document.getElementById('kursusSelectContainer').style.display = 'none';
                    document.getElementById('pathwaySelectContainer').style.display = 'none';
                } else {
                    throw new Error('Network response was not ok');
                }
            } catch (error) {
                submitRegBtn.innerText = 'Gagal, Coba Lagi';
            } finally {
                setTimeout(() => {
                    submitRegBtn.innerText = originalText;
                    submitRegBtn.style.background = '';
                    submitRegBtn.style.borderColor = '';
                    submitRegBtn.style.opacity = '1';
                    submitRegBtn.disabled = false;
                }, 3000);
            }
        });
    }
</script>

<%- include('../partials/footer') %>
