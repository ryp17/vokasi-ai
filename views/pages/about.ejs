<%- include('../partials/head', { pageTitle: 'Tentang Kami | Vokasi' }) %>

    <!-- Page Hero -->
    <section class="section" style="padding-top: calc(var(--spacing-lg) + var(--header-height)); padding-bottom: var(--spacing-lg); background-color: var(--clr-bg);">
        <div class="container">
            <div class="grid grid-2 grid-stack-md" style="align-items: center; gap: 4rem;">
                <div>
                    <div style="color: var(--clr-secondary); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem;">KISAH KAMI</div>
                    <h1 style="margin-bottom: 1.5rem; color: var(--clr-text-main); line-height: 1.2;">Membangun Masa Depan Pendidikan Digital yang Dapat Dipercaya.</h1>
                    <p style="font-size: 1.1rem; color: var(--clr-text-muted); line-height: 1.6;">Kami percaya bahwa pendidikan berkualitas tinggi tidak harus kaku atau sulit diakses. Vokasi lahir dari visi untuk menciptakan ruang belajar yang terasa seperti asisten pribadi yang ramah, memberdayakan setiap individu untuk mencapai potensi penuh mereka melalui antarmuka yang mulus dan materi kelas dunia.</p>
                </div>
                <div style="border-radius: var(--radius-md); overflow: hidden; height: 100%; min-height: 400px; background-image: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80'); background-size: cover; background-position: center;">
                </div>
            </div>
        </div>
    </section>

    <!-- Visi & Misi -->
    <section class="section" style="padding-top: 0; background-color: var(--clr-bg);">
        <div class="container">
            <div class="grid grid-2 grid-stack-md" style="gap: 2rem;">
                <!-- Visi -->
                <div class="white-card visi-misi-card" style="padding: 2.5rem; border-radius: var(--radius-lg); display: flex; flex-direction: column; gap: 1rem;">
                    <div style="background: #EFF6FF; color: var(--clr-secondary); border-radius: 50%; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                    </div>
                    <h2 style="font-size: 1.75rem; color: var(--clr-text-main); margin-top: 0.5rem;">Visi Kami</h2>
                    <p style="color: var(--clr-text-muted); font-size: 1.05rem; line-height: 1.6;">Menjadi standar emas dalam ekosistem pembelajaran digital di Indonesia, di mana teknologi dan desain humanis bersatu untuk mengeliminasi batasan dalam pendidikan berstandar tinggi.</p>
                </div>
                
                <!-- Misi -->
                <div class="white-card visi-misi-card" style="padding: 2.5rem; border-radius: var(--radius-lg); display: flex; flex-direction: column; gap: 1rem;">
                    <div style="background: #EFF6FF; color: var(--clr-secondary); border-radius: 50%; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m13.5 8.5-5 5"/><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <h2 style="font-size: 1.75rem; color: var(--clr-text-main); margin-top: 0.5rem;">Misi Kami</h2>
                    <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem;">
                        <li style="display: flex; gap: 1rem; align-items: flex-start;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 0.2rem;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span style="color: var(--clr-text-muted); font-size: 1.05rem; line-height: 1.5;">Menyajikan kurikulum industri yang relevan melalui pengalaman pengguna yang tanpa gesekan.</span>
                        </li>
                        <li style="display: flex; gap: 1rem; align-items: flex-start;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 0.2rem;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span style="color: var(--clr-text-muted); font-size: 1.05rem; line-height: 1.5;">Menumbuhkan komunitas pembelajaran yang saling mendukung dan menginspirasi.</span>
                        </li>
                        <li style="display: flex; gap: 1rem; align-items: flex-start;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 0.2rem;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span style="color: var(--clr-text-muted); font-size: 1.05rem; line-height: 1.5;">Mempertahankan komitmen pada transparansi, privasi data, dan keunggulan pedagogis.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Team -->
    <section class="section" style="background-color: var(--clr-bg);">
        <div class="container">
            <div class="text-center" style="margin-bottom: var(--spacing-lg);">
                <h2 style="color: var(--clr-text-main); margin-bottom: 0.5rem;">Tim Pemikir Kami</h2>
                <p style="color: var(--clr-text-muted); font-size: 1.1rem;">Individu-individu berdedikasi di balik platform yang mengubah cara Anda belajar.</p>
            </div>
            <div class="grid grid-team mobile-carousel" style="gap: 1.5rem;">
                <div class="white-card text-center" style="padding: 1.5rem; border-radius: var(--radius-md);">
                    <div style="border-radius: var(--radius-sm); overflow: hidden; margin-bottom: 1rem; aspect-ratio: 1; background: #e2e8f0; display: flex; align-items: flex-end; justify-content: center;">
                        <img src="https://images.unsplash.com/photo-1557862921-37829c790f19?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Ferri" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" decoding="async">
                    </div>
                    <h3 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.25rem;">Ferri</h3>
                    <p style="color: var(--clr-secondary); font-size: 0.85rem; font-weight: 600; margin: 0;">Chief Executive Officer</p>
                </div>
                <div class="white-card text-center" style="padding: 1.5rem; border-radius: var(--radius-md);">
                    <div style="border-radius: var(--radius-sm); overflow: hidden; margin-bottom: 1rem; aspect-ratio: 1; background: #e2e8f0; display: flex; align-items: flex-end; justify-content: center;">
                        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Rangga" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" decoding="async">
                    </div>
                    <h3 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.25rem;">Rangga</h3>
                    <p style="color: var(--clr-secondary); font-size: 0.85rem; font-weight: 600; margin: 0;">Head of Product</p>
                </div>
                <div class="white-card text-center" style="padding: 1.5rem; border-radius: var(--radius-md);">
                    <div style="border-radius: var(--radius-sm); overflow: hidden; margin-bottom: 1rem; aspect-ratio: 1; background: #e2e8f0; display: flex; align-items: flex-end; justify-content: center;">
                        <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Meno" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" decoding="async">
                    </div>
                    <h3 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.25rem;">Meno</h3>
                    <p style="color: var(--clr-secondary); font-size: 0.85rem; font-weight: 600; margin: 0;">Lead UX Designer</p>
                </div>
                <div class="white-card text-center" style="padding: 1.5rem; border-radius: var(--radius-md);">
                    <div style="border-radius: var(--radius-sm); overflow: hidden; margin-bottom: 1rem; aspect-ratio: 1; background: #e2e8f0; display: flex; align-items: flex-end; justify-content: center;">
                        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" alt="Natasha" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" decoding="async">
                    </div>
                    <h3 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.25rem;">Natasha</h3>
                    <p style="color: var(--clr-secondary); font-size: 0.85rem; font-weight: 600; margin: 0;">VP of Engineering</p>
                </div>
            </div>
        </div>
    </section>

<%- include('../partials/footer') %>
