    <div class="container" style="max-width: 900px;">
        <div style="text-align: center; margin-bottom: 3rem;">
            <h2 style="font-size: 2.25rem; font-weight: 800; color: var(--clr-text-main); margin-bottom: 1rem;">Tingkatan Mitra & Keuntungan</h2>
            <p style="color: var(--clr-text-muted); line-height: 1.6;">Semakin banyak pembelajar yang Anda bantu, semakin tinggi status kemitraan dan reward yang diperoleh.</p>
        </div>

        <div class="responsive-table-container">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Tingkatan</th>
                        <th>Penjualan</th>
                        <th>Komisi</th>
                        <th>Keuntungan Eksklusif</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="tier-badge tier-rintisan">Rintisan</span></td>
                        <td>0 - 5 Kursus</td>
                        <td><strong>20%</strong></td>
                        <td>Akses awal materi pemasaran & dashboard real-time.</td>
                    </tr>
                    <tr>
                        <td><span class="tier-badge tier-terampil">Terampil</span></td>
                        <td>6 - 20 Kursus</td>
                        <td><strong>22%</strong></td>
                        <td>Official Vokasi Bomber Jacket, Prioritas Dukungan Komunitas.</td>
                    </tr>
                    <tr>
                        <td><span class="tier-badge tier-ahli">Ahli</span></td>
                        <td>21 - 50 Kursus</td>
                        <td><strong>25%</strong></td>
                        <td>Branded Tech Pack & Badge Sertifikasi "Vokasi Career Advisor".</td>
                    </tr>
                    <tr>
                        <td><span class="tier-badge tier-maestro">Maestro</span></td>
                        <td>51+ Kursus</td>
                        <td><strong>30%</strong></td>
                        <td>Token Sponsor Beasiswa 100% untuk siswa di komunitas Anda.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Gotong Royong Impact Calculator Section -->
<section style="padding: 5rem 0; background: var(--clr-bg-alt); border-top: 1px solid var(--clr-border);">
    <div class="container" style="max-width: 800px; margin: 0 auto; padding: 0 1.5rem;">
        <div class="glass-card" style="padding: 3rem; border-radius: var(--radius-lg); text-align: center; background: rgba(255, 255, 255, 0.85); border: 1px solid rgba(226, 232, 240, 0.8);">
            <span style="background: rgba(16, 185, 129, 0.1); color: #059669; padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 800; letter-spacing: 0.5px; display: inline-block; margin-bottom: 1rem; text-transform: uppercase;">Kalkulator Gotong Royong</span>
            <h2 style="font-size: 2rem; font-weight: 800; color: var(--clr-text-main); margin-bottom: 1rem;">Kalkulator Dampak & Komisi</h2>
            <p style="color: var(--clr-text-muted); line-height: 1.6; margin-bottom: 2.5rem; font-size: 1rem;">
                Geser slider untuk melihat potensi komisi bulanan Anda dan kontribusi Gotong Royong untuk dana beasiswa siswa tidak mampu.
            </p>

            <div style="margin-bottom: 2.5rem;">
                <label for="salesRange" style="display: block; font-weight: 700; margin-bottom: 1rem; color: var(--clr-text-main); font-size: 1.1rem;">
                    Jumlah Penjualan Kursus per Bulan: <span id="salesVal" style="color: var(--clr-secondary); font-size: 1.5rem;">15</span> Kursus
                </label>
                <input type="range" id="salesRange" min="1" max="100" value="15" style="width: 100%; height: 8px; border-radius: 4px; background: #cbd5e1; outline: none; -webkit-appearance: none; cursor: pointer; accent-color: var(--clr-secondary);">
            </div>

            <div class="grid grid-2 grid-stack-md" style="gap: 1.5rem; text-align: left; margin-bottom: 1.5rem; display: grid;">
                <div style="background: rgba(59, 130, 246, 0.04); border-radius: var(--radius-md); padding: 1.5rem; border: 1px solid rgba(59, 130, 246, 0.1);">
                    <div style="font-size: 0.85rem; font-weight: 700; color: var(--clr-text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.5px;">ESTIMASI PENDAPATAN ANDA</div>
                    <div id="calcEarnings" style="font-size: 1.8rem; font-weight: 800; color: var(--clr-secondary);">Rp 1.646.700</div>
                    <small id="calcTier" style="color: var(--clr-text-muted); font-weight: 600; display: block; margin-top: 0.25rem;">Tingkatan: Terampil (22% Komisi)</small>
                </div>
                <div style="background: rgba(16, 185, 129, 0.04); border-radius: var(--radius-md); padding: 1.5rem; border: 1px solid rgba(16, 185, 129, 0.1);">
                    <div style="font-size: 0.85rem; font-weight: 700; color: var(--clr-text-muted); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.5px;">BEASISWA YANG DIDANAI</div>
                    <div id="calcScholarships" style="font-size: 1.8rem; font-weight: 800; color: #10B981;">0.3 Beasiswa</div>
                    <small style="color: var(--clr-text-muted); font-weight: 600; display: block; margin-top: 0.25rem;">Disalurkan ke Gotong Royong Pool</small>
                </div>
            </div>
            
            <p style="font-size: 0.85rem; color: var(--clr-text-muted); font-style: italic; margin-top: 1rem;">
                * Perhitungan didasarkan pada harga kursus rata-rata Rp 499.000. 1 beasiswa penuh bernilai Rp 4.990.000 (10 penjualan = 1 beasiswa penuh).
            </p>
        </div>
    </div>
</section>

<!-- Onboarding Registration Section -->
<section id="register" style="padding: 6rem 0; background: var(--clr-bg); border-top: 1px solid var(--clr-border);">
    <div class="container">
        <div class="glass-card signup-card">
            <div style="text-align: center; margin-bottom: 2.5rem;">
                <h2 style="font-size: 1.75rem; font-weight: 800; color: var(--clr-text-main); margin-bottom: 0.5rem;">Formulir Pendaftaran Mitra</h2>
                <p style="color: var(--clr-text-muted); font-size: 0.95rem;">Gabung sekarang secara gratis. Akun akan ditinjau dalam waktu 1x24 jam.</p>
            </div>

            <form id="affiliateRegisterForm">
                <div class="form-group-custom">
                    <label for="name">Nama Lengkap *</label>
                    <input type="text" id="name" name="name" required class="form-input-custom" placeholder="Budi Santoso">
                </div>

                <div class="form-group-custom">
                    <label for="email">Alamat Email Aktif *</label>
                    <input type="email" id="email" name="email" required class="form-input-custom" placeholder="budi@example.com">
                </div>

                <div class="form-group-custom">
                    <label for="referralCode">Kode Referal Kustom * (Untuk Tautan Anda)</label>
                    <input type="text" id="referralCode" name="referralCode" required class="form-input-custom" placeholder="BUDIVOKASI" style="text-transform: uppercase;">
                    <small style="color: var(--clr-text-muted); display: block; margin-top: 0.25rem;">Tautan Anda akan berupa: vokasi.ai/kursus-online?ref=KODE_ANDA</small>
                </div>

                <div class="form-group-custom" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <label for="paymentMethod">Metode Pembayaran Payout</label>
                        <select id="paymentMethod" name="paymentMethod" class="form-input-custom">
                            <option value="GoPay">GoPay</option>
                            <option value="OVO">OVO</option>
                            <option value="DANA">DANA</option>
                            <option value="Bank Transfer">Bank Transfer (BCA/Mandiri)</option>
                        </select>
                    </div>
                    <div>
                        <label for="paymentAccount">No. Akun / No. Rekening</label>
                        <input type="text" id="paymentAccount" name="paymentAccount" required class="form-input-custom" placeholder="0812xxxxxxxx">
                    </div>
                </div>

                <div class="form-group-custom">
                    <label for="gotongRoyongGroup">Komunitas / Sekolah (Gotong Royong Group)</label>
                    <input type="text" id="gotongRoyongGroup" name="gotongRoyongGroup" class="form-input-custom" placeholder="Contoh: SMKN 1 Jakarta / Alumni ITS / Umum">
                    <small style="color: var(--clr-text-muted); display: block; margin-top: 0.25rem;">Digunakan untuk mengumpulkan target bonus beasiswa kolektif.</small>
                </div>

                <button type="submit" id="submitRegBtn" class="btn btn-secondary btn-full" style="padding: 1rem; border-radius: var(--radius-sm); margin-top: 1rem; font-weight: 700; width: 100%;">
                    KIRIM PENGAJUAN MITRA
                </button>
            </form>
        </div>
    </div>
</section>

<!-- Login Modal -->
<div id="loginModal" class="modal-overlay">
    <div class="modal-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--clr-text-main);">Masuk Dashboard</h3>
            <button onclick="closeLoginModal()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--clr-text-muted);">&times;</button>
        </div>
        <form id="affiliateLoginForm">
            <div class="form-group-custom">
                <label for="loginKey">Email atau Kode Referal Anda</label>
                <input type="text" id="loginKey" name="loginKey" required class="form-input-custom" placeholder="budi@example.com / BUDIVOKASI">
            </div>
            <button type="submit" id="submitLoginBtn" class="btn btn-secondary btn-full" style="padding: 0.85rem; border-radius: var(--radius-sm); font-weight: 700; width: 100%;">
                MASUK DASHBOARD
            </button>
        </form>
    </div>
</div>

<!-- Scripts for interactive actions -->
<script>
    function openLoginModal() {
        document.getElementById('loginModal').classList.add('active');
    }

    function closeLoginModal() {
        document.getElementById('loginModal').classList.remove('active');
    }

    // Gotong Royong Calculator Logic
    (() => {
        const salesRange = document.getElementById('salesRange');
        const salesVal = document.getElementById('salesVal');
        const calcEarnings = document.getElementById('calcEarnings');
        const calcTier = document.getElementById('calcTier');
        const calcScholarships = document.getElementById('calcScholarships');

        if (salesRange && salesVal && calcEarnings && calcTier && calcScholarships) {
            const coursePrice = 499000;

            function updateCalculator() {
                const sales = parseInt(salesRange.value, 10);
                salesVal.innerText = sales;

                // Determine tier commission rate
                let rate = 0.20;
                let tierName = "Rintisan";
                if (sales >= 51) {
                    rate = 0.30;
                    tierName = "Maestro";
                } else if (sales >= 21) {
                    rate = 0.25;
                    tierName = "Ahli";
                } else if (sales >= 6) {
                    rate = 0.22;
                    tierName = "Terampil";
                }

                const totalRevenue = sales * coursePrice;
                const earnings = Math.round(totalRevenue * rate);
                const scholarships = (sales / 10).toFixed(1); // 10 sales funds 1 full scholarship

                // Format currency
                calcEarnings.innerText = 'Rp ' + earnings.toLocaleString('id-ID');
                calcTier.innerText = `Tingkatan: ${tierName} (${rate * 100}% Komisi)`;
                calcScholarships.innerText = `${scholarships} Beasiswa`;
            }

            salesRange.addEventListener('input', updateCalculator);
            updateCalculator(); // Initial calculation
        }
    })();

    // Auto trigger login modal if redirect has login=true query param
    window.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        if (params.get('login') === 'true') {
            openLoginModal();
        }
        if (params.get('error') === 'notfound') {
            window.showToast && window.showToast('❌ Akun tidak ditemukan. Harap periksa email/kode Anda.', true);
        }
    });

    // Handle AJAX Register Form
    const registerForm = document.getElementById('affiliateRegisterForm');
    const submitRegBtn = document.getElementById('submitRegBtn');
    if (registerForm) {
        registerForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitRegBtn.disabled = true;
            submitRegBtn.textContent = 'Memproses Pengajuan...';

            try {
                const formData = new FormData(registerForm);
                const data = Object.fromEntries(formData.entries());
                const res = await fetch('/api/affiliate/register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                
                if (res.ok && result.success) {
                    window.showToast && window.showToast('✅ Pendaftaran Berhasil! Peninjauan sedang berlangsung.');
                    registerForm.reset();
                    // Scroll to top or trigger login modal
                    setTimeout(() => {
                        window.location.href = '/affiliate?login=true';
                    }, 2000);
                } else {
                    window.showToast && window.showToast(`❌ ${result.error || 'Terjadi kesalahan.'}`, true);
                }
            } catch (err) {
                window.showToast && window.showToast('❌ Gagal menghubungi server.', true);
            } finally {
                submitRegBtn.disabled = false;
                submitRegBtn.textContent = 'KIRIM PENGAJUAN MITRA';
            }
        });
    }

    // Handle AJAX Login Form
    const loginForm = document.getElementById('affiliateLoginForm');
    const submitLoginBtn = document.getElementById('submitLoginBtn');
    if (loginForm) {
        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitLoginBtn.disabled = true;
            submitLoginBtn.textContent = 'Mengecek Akun...';

            try {
                const formData = new FormData(loginForm);
                const data = Object.fromEntries(formData.entries());
                const res = await fetch('/api/affiliate/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                
                if (res.ok && result.success) {
                    window.location.href = `/affiliate/dashboard`;
                } else {
                    window.showToast && window.showToast(`❌ ${result.error || 'Akun tidak ditemukan.'}`, true);
                }
            } catch (err) {
                window.showToast && window.showToast('❌ Gagal login.', true);
            } finally {
                submitLoginBtn.disabled = false;
                submitLoginBtn.textContent = 'MASUK DASHBOARD';
            }
        });
    }
</script>

<%- include('../partials/footer') %>
