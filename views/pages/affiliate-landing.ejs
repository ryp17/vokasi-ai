<%- include('../partials/head') %>

<!-- Link Affiliate specific styles -->
<link rel="stylesheet" href="/css/affiliate.css">

<!-- Hero Section -->
<section class="affiliate-hero">
    <div class="container" style="max-width: 800px; margin: 0 auto; padding: 0 1.5rem;">
        <span style="background: rgba(59, 130, 246, 0.15); color: #60a5fa; padding: 0.5rem 1rem; border-radius: 99px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block; margin-bottom: 1.5rem;">Vokasi Growth Engine</span>
        <h1 style="font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; margin-bottom: 1.5rem; letter-spacing: -0.02em;">
            Membangun Masa Depan Vokasi Bersama <span class="gradient-text-blue">Ambassador Vokasi</span>
        </h1>
        <p style="font-size: 1.15rem; color: #94a3b8; max-width: 600px; margin: 0 auto 2.5rem; line-height: 1.6;">
            Program kemitraan yang didesain khusus untuk para pendidik, mahasiswa, alumni, dan pemimpin komunitas di Indonesia. Dapatkan komisi berkelanjutan sambil berkontribusi bagi pendidikan vokasi.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <a href="#register" class="btn btn-secondary" style="padding: 0.85rem 2rem; font-size: 1rem; border-radius: var(--radius-sm);">Daftar Sekarang</a>
            <button onclick="openLoginModal()" class="btn btn-outline" style="padding: 0.85rem 2rem; font-size: 1rem; border-radius: var(--radius-sm); border-color: rgba(255,255,255,0.2); color: white;">Masuk ke Dashboard</button>
        </div>
    </div>
</section>

<!-- Value Proposition Section -->
