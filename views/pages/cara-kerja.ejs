<%- include('../partials/head', { pageTitle: pageTitle }) %>

<!-- Hero Section -->
<section style="padding-top: calc(var(--spacing-xl) + var(--header-height)); padding-bottom: var(--spacing-lg); background: linear-gradient(135deg, var(--clr-primary) 0%, #1E3A8A 100%); color: white; text-align: center;">
    <div class="container" style="max-width: 900px;">
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; background: rgba(255,255,255,0.1); border-radius: 50%; margin-bottom: 1.5rem; border: 1px solid rgba(255,255,255,0.2);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); margin-bottom: 1.5rem; line-height: 1.1; font-weight: 800;">
            Sistem Pembelajaran yang Didesain untuk Masa Depan
        </h1>
        <p style="font-size: 1.25rem; color: rgba(255,255,255,0.8); line-height: 1.6; max-width: 700px; margin: 0 auto 2.5rem auto;">
            Pahami perbedaan antara Kursus Online dan Jalur Karir, serta bagaimana kami menggunakan kecerdasan buatan untuk meracik kurikulum paling relevan dengan kebutuhan industri.
        </p>
    </div>
</section>

<!-- The Vokasi.ai Methodology (AI Survey translation) -->
<section style="padding: var(--spacing-xl) 0; background-color: var(--clr-bg);">
    <div class="container" style="max-width: 1000px;">
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
            <div style="position: relative;">
                <div style="position: absolute; top: -20px; left: -20px; width: 100px; height: 100px; background: #EFF6FF; border-radius: 50%; z-index: 0;"></div>
                <div style="background: white; border-radius: var(--radius-lg); padding: 2.5rem; border: 1px solid var(--clr-border); box-shadow: 0 20px 40px rgba(0,0,0,0.08); position: relative; z-index: 1;">
                    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                        <div style="display: flex; align-items: flex-start; gap: 1rem;">
                            <div style="width: 40px; height: 40px; background: var(--clr-secondary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; flex-shrink: 0;">1</div>
                            <div>
                                <h4 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.25rem;">Survei Industri Nyata</h4>
                                <p style="font-size: 0.9rem; color: var(--clr-text-muted); margin: 0; line-height: 1.5;">Mengumpulkan data dari praktisi, perekrut, dan pakar industri terkait skill yang paling dibutuhkan.</p>
                            </div>
                        </div>
                        <div style="width: 2px; height: 30px; background: #E2E8F0; margin-left: 20px;"></div>
                        <div style="display: flex; align-items: flex-start; gap: 1rem;">
                            <div style="width: 40px; height: 40px; background: #6366F1; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; flex-shrink: 0;">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                            </div>
                            <div>
                                <h4 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.25rem;">Dianalisis oleh AI Vokasi</h4>
                                <p style="font-size: 0.9rem; color: var(--clr-text-muted); margin: 0; line-height: 1.5;">Sistem AI canggih kami memproses ribuan data poin untuk menyusun silabus yang presisi dan mutakhir.</p>
                            </div>
                        </div>
                        <div style="width: 2px; height: 30px; background: #E2E8F0; margin-left: 20px;"></div>
                        <div style="display: flex; align-items: flex-start; gap: 1rem;">
                            <div style="width: 40px; height: 40px; background: #10B981; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; flex-shrink: 0;">3</div>
                            <div>
                                <h4 style="font-size: 1.1rem; color: var(--clr-text-main); margin-bottom: 0.25rem;">Modul Pembelajaran Interaktif</h4>
                                <p style="font-size: 0.9rem; color: var(--clr-text-muted); margin: 0; line-height: 1.5;">Diwujudkan menjadi materi yang atraktif, mudah dipahami, dan langsung bisa dipraktikkan.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div>
                <span style="display: inline-block; background: #EFF6FF; color: var(--clr-secondary); font-size: 0.8rem; font-weight: 800; padding: 6px 14px; border-radius: 20px; letter-spacing: 0.5px; margin-bottom: 1rem;">DITENAGAI OLEH AI</span>
                <h2 style="font-size: 2.2rem; margin-bottom: 1.5rem; color: var(--clr-text-main); line-height: 1.2;">Kurikulum yang Terus Berkembang Sesuai Tuntutan Zaman</h2>
                <p style="font-size: 1.1rem; color: var(--clr-text-muted); line-height: 1.7; margin-bottom: 1.5rem;">
                    Kami tidak menggunakan kurikulum statis. Di Vokasi.ai, kami meyakini bahwa teknologi berkembang terlalu cepat untuk metode konvensional.
                </p>
                <p style="font-size: 1.1rem; color: var(--clr-text-muted); line-height: 1.7;">
                    Kami memulai dengan melakukan <strong>survei mendalam kepada responden di industri nyata</strong>. Data mentah tersebut kemudian kami umpankan ke <strong>AI canggih buatan kami (in-house AI)</strong>, yang bertugas menerjemahkan gap kompetensi di lapangan menjadi modul pembelajaran terstruktur. Hasilnya adalah materi yang sangat atraktif, efektif, dan menjamin Anda selalu selangkah di depan.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Options Comparison -->
<section style="padding: var(--spacing-xl) 0; background-color: var(--clr-bg-alt);">
    <div class="container">
        <div style="text-center; max-width: 700px; margin: 0 auto 4rem auto; text-align: center;">
            <h2 style="font-size: 2.2rem; margin-bottom: 1rem; color: var(--clr-text-main);">Pilih Jalur Belajarmu</h2>
            <p style="font-size: 1.1rem; color: var(--clr-text-muted);">Apakah Anda ingin menguasai satu skill spesifik dalam waktu singkat, atau membangun pondasi karir yang komprehensif?</p>
        </div>

        <div class="grid grid-2" style="gap: 3rem; max-width: 1000px; margin: 0 auto;">
            
            <!-- Kursus Online -->
            <div class="white-card" style="padding: 3rem; border-radius: var(--radius-lg); border: 2px solid transparent; transition: all 0.3s ease; position: relative; overflow: hidden;" onmouseover="this.style.borderColor='var(--clr-border)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.05)';" onmouseout="this.style.borderColor='transparent'; this.style.boxShadow='none';">
                <div style="width: 64px; height: 64px; border-radius: 16px; background: #EFF6FF; color: var(--clr-secondary); display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <h3 style="font-size: 1.75rem; color: var(--clr-text-main); margin-bottom: 1rem;">Kursus Online</h3>
                <p style="color: var(--clr-text-muted); font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; min-height: 70px;">
                    Sempurna untuk Anda yang ingin memperdalam satu topik spesifik (misalnya: Meta Ads, atau UI Design) dengan cepat dan mandiri.
                </p>
                
                <h4 style="font-size: 1rem; color: var(--clr-text-main); margin-bottom: 1rem;">Apa yang Anda Dapatkan:</h4>
                <ul style="list-style: none; padding: 0; margin-bottom: 2.5rem; display: flex; flex-direction: column; gap: 0.75rem;">
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-muted); font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Akses materi seumur hidup (Lifetime Access)
                    </li>
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-muted); font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Belajar mandiri (Self-paced learning)
                    </li>
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-muted); font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Sertifikat kelulusan per modul
                    </li>
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-muted); font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Grup diskusi bersama pelajar lain
                    </li>
                </ul>
                <a href="/kursus-online" class="btn btn-outline btn-full" style="padding: 16px; border-radius: var(--radius-sm); font-weight: 700; text-align: center;">Lihat Daftar Kursus</a>
            </div>

            <!-- Jalur Karir -->
            <div class="white-card" style="padding: 3rem; border-radius: var(--radius-lg); border: 2px solid var(--clr-secondary); position: relative; box-shadow: 0 20px 40px rgba(0,0,0,0.05);">
                <div style="position: absolute; top: -16px; right: 2rem; background: var(--clr-secondary); color: white; padding: 4px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 800; letter-spacing: 0.5px;">PALING DIREKOMENDASIKAN</div>
                <div style="width: 64px; height: 64px; border-radius: 16px; background: #FCE7F3; color: #F43F5E; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <h3 style="font-size: 1.75rem; color: var(--clr-text-main); margin-bottom: 1rem;">Jalur Karir (Pathways)</h3>
                <p style="color: var(--clr-text-muted); font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; min-height: 70px;">
                    Program komprehensif berdurasi ~4 bulan yang dirancang untuk mengubah Anda dari pemula menjadi talenta siap kerja di role spesifik (contoh: AI Generalist).
                </p>
                
                <h4 style="font-size: 1rem; color: var(--clr-text-main); margin-bottom: 1rem;">Apa yang Anda Dapatkan:</h4>
                <ul style="list-style: none; padding: 0; margin-bottom: 2.5rem; display: flex; flex-direction: column; gap: 0.75rem;">
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-main); font-weight: 600; font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Semua benefit Kursus Online, PLUS:
                    </li>
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-muted); font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Mentorship intensif 1-on-1 dengan ahli industri
                    </li>
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-muted); font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Real-world Portfolio & Final Project
                    </li>
                    <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: var(--clr-text-muted); font-size: 0.95rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--clr-secondary)" stroke-width="2" style="margin-top: 2px; flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
                        Career Support (CV Review, Interview Prep) & Hiring Partner
                    </li>
                </ul>
                <a href="/jalur-karir" class="btn btn-primary btn-full" style="padding: 16px; border-radius: var(--radius-sm); font-weight: 700; text-align: center;">Eksplorasi Jalur Karir</a>
            </div>

        </div>
    </div>
</section>

<!-- Mobile Styles -->
<style>
    @media (max-width: 900px) {
        .grid { grid-template-columns: 1fr !important; }
    }
</style>

<%- include('../partials/footer') %>
