<!-- JavaScript for Interactive Tabs and Weekly Timetable -->
<script>
    function switchStudyTab(tabType) {
        // Toggle Active Button
        document.querySelectorAll('.study-tab-btn').forEach(btn => btn.classList.remove('active'));
        if (tabType === 'online') {
            document.getElementById('tab-btn-online').classList.add('active');
        } else {
            document.getElementById('tab-btn-karir').classList.add('active');
        }

        // Toggle Active Content
        document.querySelectorAll('.study-tab-content').forEach(content => {
            content.classList.remove('active-content');
        });
        
        setTimeout(() => {
            if (tabType === 'online') {
                document.getElementById('tab-content-online').classList.add('active-content');
            } else {
                document.getElementById('tab-content-karir').classList.add('active-content');
            }
        }, 50);
    }

    // Schedule details mapping
    const scheduleData = {
        senin: {
            title: "SENIN — Live Mentoring 1: Kick-off & Teori",
            desc: "Sesi Live Mentoring tatap muka via Zoom (19:30 - 21:00 WIB). Mentor memperkenalkan topik utama minggu ini, membedah studi kasus nyata dari industri, serta memberikan penugasan praktik mingguan."
        },
        selasa: {
            title: "SELASA — Belajar Mandiri & AI Support",
            desc: "Tonton modul video pendukung secara mandiri. Praktikkan langsung instruksi yang dipelajari dan gunakan asisten AI Tutor 24/7 jika kamu mengalami kendala teknis."
        },
        rabu: {
            title: "RABU — Live Mentoring 2: Bedah Kasus & QA",
            desc: "Sesi Live Mentoring tatap muka online kedua (19:30 - 21:00 WIB). Fokus pada pemecahan masalah bersama, sesi tanya jawab mendalam, serta evaluasi hasil belajar mandiri sejauh ini."
        },
        kamis: {
            title: "KAMIS — Fokus Konstruksi Portofolio",
            desc: "Waktunya menuangkan pemahamanmu ke dalam tugas mingguan. Mulai kerjakan aset portofolio nyata yang bisa dipamerkan di CV kamu nanti."
        },
        jumat: {
            title: "JUMAT — Live Mentoring 3: Final Review",
            desc: "Sesi Live Mentoring tatap muka online ketiga (19:30 - 21:00 WIB). Setiap siswa mengunggah tugas mingguan mereka untuk ditinjau dan diberi feedback langsung oleh mentor."
        },
        sabtu: {
            title: "SABTU — Career Prep & Evaluasi Mandiri",
            desc: "Gunakan hari ini untuk merevisi portofolio berdasarkan catatan mentor, membaca materi pengayaan karir, atau berjejaring di komunitas alumni Vokasi."
        }
    };

    function showScheduleDetail(dayKey) {
        // Highlight active schedule day item
        document.querySelectorAll('.schedule-day').forEach(el => el.classList.remove('active-day'));
        
        // Find which index matches dayKey to add active class
        const indexMap = { senin: 1, selasa: 2, rabu: 3, kamis: 4, jumat: 5, sabtu: 6 };
        const index = indexMap[dayKey];
        if (index) {
            const selector = `.weekly-schedule-grid .schedule-day:nth-child(${index})`;
            const activeEl = document.querySelector(selector);
            if (activeEl) activeEl.classList.add('active-day');
        }

        // Apply content updates with a quick animation effect
        const detailCard = document.getElementById('schedule-detail-card');
        detailCard.style.opacity = '0.5';
        
        setTimeout(() => {
            document.getElementById('detail-day-title').innerText = scheduleData[dayKey].title;
            document.getElementById('detail-day-desc').innerText = scheduleData[dayKey].desc;
            detailCard.style.opacity = '1';
        }, 150);
    }
</script>

