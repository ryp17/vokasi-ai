                <header style="margin-bottom: 3rem;">
                    <span style="display: inline-block; background: #EFF6FF; color: var(--clr-secondary); font-size: 0.8rem; font-weight: 800; padding: 6px 14px; border-radius: 20px; letter-spacing: 0.5px; margin-bottom: 1.5rem;">PANDUAN</span>
                    <h1 style="font-size: clamp(2rem, 6vw, 3.5rem); color: var(--clr-text-main); margin-bottom: 1.5rem; line-height: 1.2;">Panduan Memilih Bootcamp yang Tepat untuk Karir Anda</h1>
                    
                    <div style="display: flex; align-items: center; gap: 1rem; border-top: 1px solid var(--clr-border); border-bottom: 1px solid var(--clr-border); padding: 1.5rem 0; margin-top: 2rem;">
