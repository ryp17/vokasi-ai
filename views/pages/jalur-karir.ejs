        function showScheduleDetail(dayKey) {
            // Highlight active schedule day item
            document.querySelectorAll('.schedule-day').forEach(el => el.classList.remove('active-day'));
            
            // Find which index matches dayKey to add active class
            const indexMap = { senin: 1, selasa: 2, rabu: 3, kamis: 4, jumat: 5, sabtu: 6 };
            const index = indexMap[dayKey];
            if (index) {
                const selector = `.weekly-schedule-grid .schedule-day:nth-child(${index})`;
                const activeEl = document.querySelector(selector);
                if (activeEl) activeEl.classList.add('active-day');
            }

            // Apply content updates with a quick animation effect
            const detailCard = document.getElementById('schedule-detail-card');
            detailCard.style.opacity = '0.5';
            
            setTimeout(() => {
                document.getElementById('detail-day-title').innerText = scheduleData[dayKey].title;
