    <script>
        function selectTier(index, price, tierName) {
            const toast = document.getElementById('timeline-interactive-toast');
            const toastText = document.getElementById('interactive-toast-text');
            
            if (index === 1) {
                toastText.innerHTML = `💡 <strong>Founder Tier Terbuka:</strong> Dapatkan harga terendah <strong>$1 (Rp 16.000)</strong> sebelum 98 kursi berikutnya terisi dan harga naik otomatis.`;
                toast.style.background = 'rgba(16, 185, 129, 0.05)';
                toast.style.borderColor = 'rgba(16, 185, 129, 0.15)';
            } else {
                const idrPrice = price * 16000;
                const formattedIdr = idrPrice.toLocaleString('id-ID');
                toastText.innerHTML = `🔒 <strong>${tierName} ($${price} / Rp ${formattedIdr}):</strong> Tier ini saat ini masih terkunci. Akan aktif secara otomatis setelah kuota slot 1 - ${price * 100 - 100} terisi penuh. <strong>Amankan harga $1 hari ini!</strong>`;
                toast.style.background = 'rgba(59, 130, 246, 0.05)';
                toast.style.borderColor = 'rgba(59, 130, 246, 0.15)';
            }
            
            // Highlight step card border
            document.querySelectorAll('.timeline-step').forEach((el, idx) => {
                if (idx + 1 === 1) {
                    el.style.borderColor = '#10B981';
                } else {
                    el.style.borderColor = 'var(--clr-border)';
                }
            });
            
            // Find index step (using child selector)
            const stepCard = document.querySelector(`.timeline-steps .timeline-step:nth-child(${index})`);
            if (stepCard && index !== 1) {
                stepCard.style.borderColor = 'var(--clr-secondary)';
            }
        }
    </script>

