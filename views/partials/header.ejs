<header class="site-header">
    <div class="container">
        <!-- Left: Logo -->
        <a href="/" class="logo-link" style="display: flex; align-items: center;">
            <img src="/assets/vokasi_logo.png" alt="Vokasi.ai Logo" style="height: 48px; width: auto; object-fit: contain;">
        </a>

        <!-- Center: Nav -->
        <nav class="main-nav">
            <ul>
                <li><a href="/" class="nav-link<%= currentPath === '/' ? ' active' : '' %>">Home</a></li>
