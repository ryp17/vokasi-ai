    <!-- Toast Notification -->
    <div id="toast" style="
        position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(120px);
        background: var(--clr-secondary); color: #fff;
        padding: 1rem 2rem; border-radius: var(--radius-md);
        font-weight: 600; font-size: 0.95rem; z-index: 9999;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        pointer-events: none; white-space: nowrap;
    " role="status" aria-live="polite"></div>

    <script src="/js/affiliate-tracker.js"></script>
    <script>
        (() => {
            // --- Toast Utility ---
            function showToast(message, isError = false) {
                const toast = document.getElementById('toast');
                if (!toast) return;
                toast.textContent = message;
                toast.style.background = isError ? '#c0392b' : 'var(--clr-secondary)';
                toast.style.transform = 'translateX(-50%) translateY(0)';
                setTimeout(() => {
                    toast.style.transform = 'translateX(-50%) translateY(120px)';
                }, 4000);
            }

            // Make showToast available globally if needed by other scripts
            window.showToast = showToast;

            // --- AJAX Form Submission ---
            const applyForm = document.getElementById('applyForm');
            const submitBtn = document.getElementById('submitBtn');
            if (applyForm && submitBtn) {
                applyForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    submitBtn.textContent = 'Mengirim...';
                    submitBtn.disabled = true;

                    try {
                        const formData = new FormData(applyForm);
                        const body = Object.fromEntries(formData.entries());
                        const res = await fetch('/api/apply', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(body),
                        });
                        const data = await res.json();
                        if (res.ok && data.success) {
                            showToast('✅ Pengajuan berhasil! Kami akan menghubungi Anda segera.');
                            applyForm.reset();
                        } else {
                            showToast('❌ Terjadi kesalahan. Coba lagi.', true);
                        }
                    } catch (err) {
                        showToast('❌ Koneksi gagal. Periksa internet Anda.', true);
                    } finally {
                        submitBtn.textContent = 'AJUKAN BEASISWA';
                        submitBtn.disabled = false;
                    }
                });
            }

            // --- Mobile Nav Toggle ---
            const toggleBtn = document.querySelector('.mobile-toggle');
            const nav = document.querySelector('.main-nav');
            if (toggleBtn && nav) {
                toggleBtn.addEventListener('click', () => {
                    nav.classList.toggle('active');
                });
                // Close nav when any nav link is clicked (mobile)
                nav.querySelectorAll('a').forEach(link => {
                    link.addEventListener('click', () => {
                        nav.classList.remove('active');
                    });
                });
            }

            // --- FAQ Accordion ---
            document.querySelectorAll('.faq-question').forEach(btn => {
                btn.addEventListener('click', () => {
                    const isOpen = btn.getAttribute('aria-expanded') === 'true';
                    // Close all
                    document.querySelectorAll('.faq-question').forEach(b => {
                        b.setAttribute('aria-expanded', 'false');
                        b.nextElementSibling.classList.remove('open');
                    });
                    // Open clicked if it was closed
                    if (!isOpen) {
                        btn.setAttribute('aria-expanded', 'true');
                        btn.nextElementSibling.classList.add('open');
                    }
                });
            });
        })();
    </script>
